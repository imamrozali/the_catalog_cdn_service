# API Key untuk autentikasi upload/delete (Bearer token)
# Wajib diubah di production! Gunakan minimal 32 karakter random
CDN_API_KEY=your-cdn-api-key

# Port server
PORT=4001

# URL prefix untuk akses file (default: /cdn)
CDN_PREFIX=/cdn

# Direktori penyimpanan file upload (default: ./uploads)
UPLOAD_DIR=./uploads

# Max file size per file (bytes). Default: 10485760 (10MB)
MAX_FILE_SIZE=10485760

# Allowed origins untuk CORS (pisahkan dengan koma)
ALLOWED_ORIGINS=https://reevantstore.com
