# API Key untuk autentikasi upload/delete (Bearer token)
# Wajib diubah di production! Minimal 32 karakter random
CDN_API_KEY=your-cdn-api-key

# Port server
PORT=4001

# URL prefix untuk akses file (default: /cdn)
CDN_PREFIX=/cdn

# Direktori penyimpanan file upload (default: ./uploads/products)
# Di production, gunakan absolute path untuk konsistensi
UPLOAD_DIR=./uploads/store

# Max file size per file (bytes). Default: 10485760 (10MB)
MAX_FILE_SIZE=10485760

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info
