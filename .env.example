# API Key untuk autentikasi upload/delete (Bearer token)
# Wajib diubah di production!
CDN_API_KEY=porto-cdn-dev-key

# Port server
PORT=4001

# URL prefix untuk akses file (default: /cdn)
CDN_PREFIX=/cdn

# Direktori penyimpanan file upload (default: ./uploads)
UPLOAD_DIR=./uploads

# Max file size per file (bytes). Default: 10485760 (10MB)
MAX_FILE_SIZE=10485760
